# Copy to .env and fill in your values. Never commit .env.
# For GitHub Actions, set these as repo secrets instead (gh secret set NAME --body "value").

# Anthropic — Claude (analysis, captions, slide copy)
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Apify — Instagram scraping (apify/instagram-scraper actor)
# Get from https://console.apify.com/settings/integrations
APIFY_API_KEY=

# OpenAI — gpt-image-1 for branded LinkedIn visual PNGs
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Notion — content calendar database for carousels
# Get key from https://www.notion.so/my-integrations
# Get DB ID from your database URL (the 32-char hex after the workspace name)
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Make.com — webhook that publishes the LinkedIn visual + caption
# Create scenario at https://make.com → Webhooks → Custom webhook → copy URL
MAKE_WEBHOOK_URL=
